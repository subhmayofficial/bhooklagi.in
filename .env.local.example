# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Settings -> API -> service_role secret. Server-only, never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# MSG91 OTP Widget (https://control.msg91.com -> OTP -> Widgets)
NEXT_PUBLIC_MSG91_WIDGET_ID=
NEXT_PUBLIC_MSG91_AUTH_TOKEN=
# Optional: a VALID MSG91 account authkey to verify widget access tokens.
# Leave blank to reuse NEXT_PUBLIC_MSG91_AUTH_TOKEN above (the widget auth token is
# a valid authkey and is the intended credential for widget endpoints).
MSG91_AUTHKEY=

# Session cookie signing secret. Generate with: openssl rand -base64 32
AUTH_SESSION_SECRET=

# Password to log into /admin. Set your own before deploying.
ADMIN_PASSWORD=
