# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Settings -> API -> service_role secret. Server-only, never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# MSG91 OTP Widget (https://control.msg91.com -> OTP -> Widgets)
NEXT_PUBLIC_MSG91_WIDGET_ID=
NEXT_PUBLIC_MSG91_AUTH_TOKEN=
# Account authkey (Settings -> API), used server-side to verify widget access
# tokens. This is REQUIRED for login: only the account authkey validates tokens
# (returns code 701 for a bad token / success for a good one). The widget token
# alone cannot verify. Make sure IP Security is OFF for this authkey so server
# calls aren't blocked.
MSG91_AUTHKEY=

# Session cookie signing secret. Generate with: openssl rand -base64 32
AUTH_SESSION_SECRET=

# Password to log into /admin. Set your own before deploying.
ADMIN_PASSWORD=

# UPI ID for online payment deep link on the order tracking page.
NEXT_PUBLIC_UPI_ID=
